---
import "../styles/global.css";
export interface Props {
  title: string;
}

const { title } = Astro.props;

//import { Image } from "astro:assets";
//import image from "../assets/vectors/image.svg";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Precargar el audio -->
    <link rel="preload" href="/sounds/SFX_1.mp3" as="audio" type="audio/mpeg" />
  </head>
  <body>
    <!--
    <header class="header">
      <nav>
        <a href="/projects" class="nav_btn">Projects</a>
        <a href="/" class="nav_btn">Home</a>
      </nav>
    </header>
    -->

    <slot />

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const hoverSound = new Audio("/sounds/SFX_1.mp3");
        hoverSound.volume = 0.3;
        hoverSound.preload = "auto";
        hoverSound.load();

        let audioUnlocked = false;

        const unlockAudio = () => {
          if (audioUnlocked) return;
          audioUnlocked = true;
          hoverSound.muted = true;
          hoverSound
            .play()
            .then(() => {
              hoverSound.pause();
              hoverSound.currentTime = 0;
              hoverSound.muted = false;
            })
            .catch(() => {});
          document.removeEventListener("click", unlockAudio);
          document.removeEventListener("touchstart", unlockAudio);
          document.removeEventListener("keydown", unlockAudio);
        };

        document.addEventListener("click", unlockAudio);
        document.addEventListener("touchstart", unlockAudio);
        document.addEventListener("keydown", unlockAudio);

        // Sonido en todos los botones de navegación
        document.querySelectorAll(".nav_btn").forEach((btn) => {
          btn.addEventListener("mouseenter", () => {
            if (audioUnlocked) {
              hoverSound.currentTime = 0;
              hoverSound.play().catch((error) => {
                console.log("Error al reproducir:", error);
              });
            }
          });
        });

        // Marcar link activo
        document.querySelectorAll(".header nav a").forEach((link) => {
          if (link.getAttribute("href") === window.location.pathname) {
            link.classList.add("active");
          }
        });
      });
    </script>
  </body>
</html>
